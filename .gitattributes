# Keep text diffs consistent across contributors and platforms.
* text=auto eol=lf

# Common game assets should never be line-ending normalized.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ogg binary
*.wav binary
*.mp3 binary
*.ttf binary
*.otf binary
*.blend binary
*.glb binary

# Keep the vendored GUT release byte-for-byte compatible with its upstream formatting.
addons/gut/** -whitespace
