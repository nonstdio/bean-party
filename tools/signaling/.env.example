# Bean Party hosted WebRTC signaling service
# Copy to your secret store / Railway variables. Do not commit real values.

# Railway provides PORT automatically.
HOST=0.0.0.0

# HTTP paths
SIGNALING_PATH=/v1/signal
ICE_PATH=/v1/ice
SIGNALING_PROTOCOL_VERSION=1

# Capacity and lifecycle
MAX_CONNECTIONS=4096
MAX_ROOMS=1024
MAX_PEERS_PER_ROOM=4
MAX_SIGNALING_PAYLOAD_BYTES=65536
MAX_HTTP_BODY_BYTES=16384
ROOM_INACTIVITY_MS=1800000
ROOM_MAX_LIFETIME_MS=14400000

# ICE / TURN (coturn REST API shared-secret mode)
STUN_URLS=stun:stun.l.google.com:19302
TURN_URLS=
TURNS_URLS=
TURN_SHARED_SECRET=
TURN_CREDENTIAL_TTL_SEC=3600
TURN_CREDENTIAL_MAX_TTL_SEC=86400

# Rate limits
CONNECTION_RATE_LIMIT_MAX=120
ROOM_CREATE_RATE_LIMIT_MAX=30
ROOM_JOIN_RATE_LIMIT_MAX=60
ICE_RATE_LIMIT_MAX=30

# Proxy trust (disabled by default)
TRUST_PROXY=false

# Logging
LOG_LEVEL=info
